# Nautilus MCP Server - Exemplo de configuração
# Copie para .env e preencha com suas credenciais (nunca commite .env)

# Conexões - use o padrão DATABASES__<connection_id>__<key>
# connection_id deve ser alfanumérico com underscores (ex: pg_main, mysql_analytics)
# read_only é true por padrão; informe só se quiser desabilitar: DATABASES__<id>__read_only=false

# PostgreSQL (exemplo)
# DATABASES__pg_main__type=postgresql
# DATABASES__pg_main__url=postgresql://user:password@localhost:5432/mydb

# MySQL (exemplo)
# DATABASES__mysql_analytics__type=mysql
# DATABASES__mysql_analytics__url=mysql://user:password@localhost:3306/analytics

# SQL Server (exemplo)
# DATABASES__sqlserver_erp__type=sqlserver
# DATABASES__sqlserver_erp__url=odbc://DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=erp;UID=user;PWD=password

# Oracle (exemplo). URL: oracle://user:password@host:port/service_name
# DATABASES__oracle_erp__type=oracle
# DATABASES__oracle_erp__url=oracle://user:password@localhost:1521/ORCL

# MongoDB (exemplo)
# DATABASES__mongo_catalog__type=mongodb
# DATABASES__mongo_catalog__url=mongodb://user:password@localhost:27017/

# Redis (exemplo)
# DATABASES__redis_cache__type=redis
# DATABASES__redis_cache__url=redis://localhost:6379/0

# Limites de segurança (opcional). Timeout vale para todas as consultas; max_rows é o teto de linhas.
# O agente pode pedir menos linhas via parâmetro max_rows nas tools; LIMIT/TOP na query não pode exceder max_rows.
# NAUTILUS_QUERY_MAX_LENGTH=2000
# NAUTILUS_QUERY_TIMEOUT_SECONDS=30
# NAUTILUS_MAX_ROWS=500
# NAUTILUS_ALLOW_WRITE=false
# NAUTILUS_CONFIRM_WRITE_TOKEN=   # Token para execute_confirmed_write (human-in-the-loop)
# NAUTILUS_SAVED_QUERIES_JSON=saved_queries.json   # Caminho para o arquivo de queries salvas
