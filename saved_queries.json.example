{
  "queries": [
    {
      "name": "top_usuarios",
      "description": "Top N usuários por nome",
      "query_template": "SELECT * FROM users ORDER BY name LIMIT {{limit}}",
      "parameters": ["limit"]
    },
    {
      "name": "usuarios_por_status",
      "description": "Usuários filtrados por status",
      "query_template": "SELECT * FROM users WHERE status = '{{status}}' LIMIT 100",
      "parameters": ["status"]
    }
  ]
}
