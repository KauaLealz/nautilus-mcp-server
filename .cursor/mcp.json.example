{
  "mcpServers": {
    "nautilus": {
      "command": "npx",
      "args": ["-y", "nautilus-mcp-server@latest"],
      "env": {
        "DATABASES__pg__type": "postgresql",
        "DATABASES__pg__host": "localhost",
        "DATABASES__pg__port": "5432",
        "DATABASES__pg__user": "nautilus",
        "DATABASES__pg__password": "nautilus",
        "DATABASES__pg__database": "nautilus",
        "DATABASES__mysql_demo__type": "mysql",
        "DATABASES__mysql_demo__host": "localhost",
        "DATABASES__mysql_demo__port": "3306",
        "DATABASES__mysql_demo__user": "root",
        "DATABASES__mysql_demo__password": "secret",
        "DATABASES__mysql_demo__database": "demo",
        "DATABASES__mongo__type": "mongodb",
        "DATABASES__mongo__url": "mongodb://localhost:27017/",
        "DATABASES__redis__type": "redis",
        "DATABASES__redis__url": "redis://localhost:6379/0"
      }
    }
  }
}
